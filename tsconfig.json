{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@popper/cache": ["packages/cache/src"],
      "@popper/core": ["packages/core/src"],
      "@popper/db": ["packages/db/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".turbo"]
}
