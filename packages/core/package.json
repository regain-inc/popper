{
  "name": "@popper/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@regain/hermes": "^1.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.0"
  }
}
