# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/popper

# Better Auth
# Generate a random 32+ character secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand
BETTER_AUTH_URL=http://localhost:3002

# App URL (used for invite links, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# API URL (Popper server)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Mock mode (set to 'true' to use hardcoded mock data instead of real API)
NEXT_PUBLIC_USE_MOCK=true

# API Key for Popper server (optional in demo mode)
NEXT_PUBLIC_API_KEY=

# Email (Resend)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Sender email (must be verified domain in Resend, or use onboarding@resend.dev for testing)
EMAIL_FROM=Popper <noreply@yourdomain.com>

# Initial Admin User (for seeding)
# Run: cd packages/db && bun run db:seed-admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme
