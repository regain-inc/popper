{
  "name": "@popper/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "import": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/opentelemetry": "^1.4.10",
    "@logtape/logtape": "^2.0.2",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.211.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.211.0",
    "@opentelemetry/sdk-metrics": "^2.5.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@popper/auth": "workspace:*",
    "@popper/cache": "workspace:*",
    "@popper/core": "workspace:*",
    "@popper/db": "workspace:*",
    "@regain/hermes": "^1.0.3",
    "bullmq": "^5.34.0",
    "elysia": "^1.4.22",
    "elysia-prometheus": "^1.0.0",
    "graceful-server-elysia": "^1.0.25",
    "ioredis": "^5.4.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "bun-types": "^1.3.0"
  }
}
